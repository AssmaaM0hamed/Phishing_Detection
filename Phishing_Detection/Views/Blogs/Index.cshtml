            <div class="col">
                <div class="card h-100 articleCard rounded-4">
                    <img src="~/Images/blog7.jpg" class=" rounded-top-4" alt="Avoid Links Graphic">
                    <div class="card-body d-flex flex-column">
                        <div class="flex-grow-1">
                            <h6 class="card-title  mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                5 Essential Tips for Avoiding Malicious Links
                            </h6>
                            <p class="card-text text-secondary fw-light mb-2" style="white-space: normal; line-height: 1;">
								<small> 5 Essential Tips for Avoiding Malicious Links</small>
                            </p>
                        </div>
                        <a asp-action="AvoidingMaliciousLinksArticle" asp-controller="Blogs" class="text-primary text-decoration-none mt-auto">Read More</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<partial name="_ContactUs" />