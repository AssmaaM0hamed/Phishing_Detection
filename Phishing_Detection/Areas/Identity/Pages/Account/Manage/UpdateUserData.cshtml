@page
@model UpdateUserDataModel
@{
    ViewData["Title"] = "Update Your Profile";
    ViewData["ActivePage"] = "Update";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-blue">Update Profile</h2>
    </div>
    <div class="card shadow-sm p-4 mt-5">
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success text-center">@Model.StatusMessage</div>
        }
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Input.FirstName" class="form-control" />
                        <label asp-for="Input.FirstName">First Name</label>
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Input.LastName" class="form-control" />
                        <label asp-for="Input.LastName">Last Name</label>
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Input.DateOfBirth" type="date" class="form-control" />
                        <label asp-for="Input.DateOfBirth">Date of Birth</label>
                        <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Input.Email" class="form-control" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                </div>
                
            </div>
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Input.CheckCount" class="form-control" readonly="readonly" />
                        <label asp-for="Input.CheckCount">Check Count</label>
                        <span asp-validation-for="Input.CheckCount" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Input.LastLoginDate" class="form-control" type="date" readonly="readonly" value="@(Model.Input.LastLoginDate?.ToString("yyyy-MM-dd") ?? "N/A")" />
                        <label asp-for="Input.LastLoginDate">Last Login Date</label>
                        <span asp-validation-for="Input.LastLoginDate" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="row my-4 ">
                
                <div class="col-md-6 d-flex align-items-center">
                    <div class="form-check">
                        <input asp-for="Input.ReceiveNotifications" class="form-check-input" />
                        <label asp-for="Input.ReceiveNotifications" class="form-check-label">Receive Notifications</label>
                        <span asp-validation-for="Input.ReceiveNotifications" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-blue">Save Changes</button>
                <a asp-page="/Account/Manage/Index" class="btn btn-secondary ms-3">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
